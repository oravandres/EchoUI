# Copy to `.env.development` or `.env.production` (both gitignored except this file).
# Public values only — never put secrets in Vite env (they are embedded in the bundle).

# Echo HTTP API base URL (no trailing slash).
# - Dev: optional; defaults to http://localhost:8001 when unset.
# - Production build: required (validated at `vite build` time).
# VITE_ECHO_API_BASE_URL=http://localhost:8001
# VITE_ECHO_API_BASE_URL=https://echo.mimi.local
